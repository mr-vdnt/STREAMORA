# Environment
STREAMORA_ENV=development

# Concurrency
MAX_GENERATOR_WORKERS=5

# Feature Flags
ENABLE_EXACT=True
ENABLE_SEMANTIC=True
ENABLE_METADATA=True
ENABLE_PERSONALIZATION=True
ENABLE_GRAPH=True
ENABLE_BUSINESS_RULES=True
ENABLE_DIVERSITY=True
ENABLE_LLM=True
ENABLE_CACHE=True
ENABLE_TRACING=True

# External Services
LLM_MODEL=llama3
LLM_TIMEOUT_MS=3000

# File Paths
MOVIES_CSV_PATH=data/raw/movies.csv
FAISS_INDEX_PATH=data/index/movies.index
